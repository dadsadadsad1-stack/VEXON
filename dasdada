local function removeOldMessages()
	local rows = {}
	for _, c in ipairs(ScrollFrame:GetChildren()) do
		if c:IsA("Frame") and c.Name == "MsgRow" then
			table.insert(rows, c)
		end
	end
	while #rows > CONFIG.MaxMessages do
		rows[1]:Destroy()
		table.remove(rows, 1)
	end
end

local function addMessage(data)
	messageCount += 1
	if not isChatOpen and data.type ~= "system" then
		NotifDot.BackgroundTransparency = 0
	end

	local row = Instance.new("Frame")
	row.Name                   = "MsgRow"
	row.BackgroundTransparency = 1
	row.LayoutOrder            = messageCount
	row.Parent                 = ScrollFrame

	local label = Instance.new("TextLabel")
	label.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
	label.BackgroundTransparency = 0.45
	label.TextColor3             = Color3.fromRGB(255, 255, 255)
	label.Font                   = Enum.Font.Gotham
	label.TextSize               = CONFIG.FontSize
	label.TextXAlignment         = Enum.TextXAlignment.Left
	label.TextYAlignment         = Enum.TextYAlignment.Top
	label.TextWrapped            = true
	label.RichText               = true
	label.BorderSizePixel        = 0
	label.Parent                 = row

	local lPad = Instance.new("UIPadding")
	lPad.PaddingLeft   = UDim.new(0, 5)
	lPad.PaddingRight  = UDim.new(0, 5)
	lPad.PaddingTop    = UDim.new(0, 2)
	lPad.PaddingBottom = UDim.new(0, 2)
	lPad.Parent        = label

	local ts = ""
	if CONFIG.TimestampsEnabled then
		ts = string.format('<font color="#aaaaaa"><font size="%d">[%s] </font></font>', CONFIG.FontSize - 2, getTimestamp())
	end

	local rt = ""
	if data.type == "system" then
		rt = ts .. string.format('<font color="#aaeeff"><i>%s</i></font>', data.text)
	elseif data.type == "error" then
		rt = ts .. string.format('<font color="#ff6666"><b>[Error]</b> %s</font>', data.text)
	elseif data.type == "admin" then
		rt = ts .. string.format('<font color="#ff4444"><b>[ADMIN] </b></font><font color="#ffaaaa">%s</font>', data.text)
	elseif data.type == "relay" then
		rt = ts .. data.roleTag .. string.format('<font color="#ccccff"><b>%s</b></font><font color="#ffffff">: %s</font>', data.username, filterText(data.text))
	elseif data.type == "whisper" then
		local prefix = data.incoming and "From" or "To"
		local whom   = data.speaker and data.speaker.DisplayName or "?"
		rt = ts .. string.format('<font color="#ffccf0"><b>[%s %s]: </b>%s</font>', prefix, whom, filterText(data.text))
	elseif data.type == "team" then
		local displayName = data.speaker and data.speaker.DisplayName or "Server"
		rt = ts .. string.format('<font color="#88ff88"><b>[Team] %s: </b></font><font color="#ccffcc">%s</font>', displayName, filterText(data.text))
	elseif data.type == "global" then
		if data.speaker then
			local c   = data.color or getNameColor(data.speaker)
			local hex = string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
			local tag = getRoleTag(data.speaker)
			rt = ts .. '<font color="#FFAA00"><b>[GLOBAL] </b></font>' .. tag .. string.format('<font color="%s"><b>%s</b></font><font color="#ffffff">: %s</font>', hex, data.speaker.DisplayName, filterText(data.text))
		else
			rt = ts .. filterText(data.text)
		end
	else
		if data.speaker then
			local c   = data.color or getNameColor(data.speaker)
			local hex = string.format("#%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
			local tag = getRoleTag(data.speaker)
			rt = ts .. tag .. string.format('<font color="%s"><b>%s</b></font><font color="#ffffff">: %s</font>', hex, data.speaker.DisplayName, filterText(data.text))
		else
			rt = ts .. filterText(data.text)
		end
	end

	label.Text = rt

	-- Calculate height from text and apply fixed sizes
	local rowWidth   = CONFIG.WindowWidth - 12
	local plainText  = rt:gsub("<[^>]+>", "")
	local textH      = getTextHeight(plainText, CONFIG.FontSize, rowWidth)
	local rowH       = textH + 8
	row.Size         = UDim2.new(1, 0, 0, rowH)
	label.Size       = UDim2.new(1, 0, 1, 0)
	canvasHeight     = canvasHeight + rowH + 1

	removeOldMessages()
	scrollToBottom()
	lastActivityTime = tick()

	if not isChatVisible and isChatOpen then
		for _, r in ipairs(ScrollFrame:GetChildren()) do
			if r:IsA("Frame") then
				for _, lbl in ipairs(r:GetChildren()) do
					if lbl:IsA("TextLabel") then
						TweenService:Create(lbl, TweenInfo.new(0.3), {BackgroundTransparency = 0.45, TextTransparency = 0}):Play()
					end
				end
			end
		end
		TweenService:Create(ScrollFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1 - CONFIG.BackgroundAlpha}):Play()
		isChatVisible = true
	end
end

local function createChatBubble(character, text)
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	local existing = head:FindFirstChild("VexonBubble")
	if existing then existing:Destroy() end

	local bb = Instance.new("BillboardGui")
	bb.Name        = "VexonBubble"
	bb.Size        = UDim2.new(0, 200, 0, 50)
	bb.StudsOffset = Vector3.new(0, 2.5, 0)
	bb.AlwaysOnTop = false
	bb.MaxDistance = 60
	bb.Parent      = head

	local bg = Instance.new("Frame")
	bg.Size                   = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
	bg.BackgroundTransparency = 0.08
	bg.BorderSizePixel        = 0
	bg.Parent                 = bb
	Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 8)

	local lbl = Instance.new("TextLabel")
	lbl.Size                   = UDim2.new(1, -10, 1, 0)
	lbl.Position               = UDim2.new(0, 5, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.TextColor3             = Color3.fromRGB(30, 30, 30)
	lbl.Font                   = Enum.Font.GothamMedium
	lbl.TextSize               = 13
	lbl.TextWrapped            = true
	lbl.Text                   = truncate(text, CONFIG.BubbleMaxLength)
	lbl.Parent                 = bg

	task.delay(CONFIG.BubbleDuration, function()
		if bb and bb.Parent then
			TweenService:Create(bb, TweenInfo.new(0.5), {StudsOffsetWorldSpace = Vector3.new(0, 0.5, 0)}):Play()
			task.wait(0.5)
			bb:Destroy()
		end
	end)
end

