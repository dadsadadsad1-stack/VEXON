local function premiumKick(target, reason)
	if isPremium(target) then
		addMessage({ type = "error", text = "Cannot kick a vexonhub-premium user." })
		return
	end
	addMessage({ type = "admin", text = "Kicked " .. target.Name .. (reason ~= "" and (" — " .. reason) or "") })
	pcall(function()
		target:Kick(reason ~= "" and reason or "Kicked by vexonhub-premium user.")
	end)
end

local function premiumFire(target)
	if isPremium(target) then
		addMessage({ type = "error", text = "Cannot fire a vexonhub-premium user." })
		return
	end
	local char = getCharacter(target)
	if not char then addMessage({ type = "error", text = target.Name .. " has no character." }) return end
	local root = getRootPart(target)
	if root then
		local fire = Instance.new("Fire")
		fire.Size   = 3
		fire.Heat   = 9
		fire.Parent = root
		addMessage({ type = "admin", text = "Set " .. target.Name .. " on fire." })
		task.delay(10, function() pcall(function() fire:Destroy() end) end)
	end
end

local function premiumFreeze(target)
	if isPremium(target) then
		addMessage({ type = "error", text = "Cannot freeze a vexonhub-premium user." })
		return
	end
	local hum = getHumanoid(target)
	local char = getCharacter(target)
	if not hum or not char then addMessage({ type = "error", text = target.Name .. " has no character." }) return end

	frozenPlayers[target.UserId] = true
	hum.WalkSpeed   = 0
	hum.JumpPower   = 0
	hum.JumpHeight  = 0

	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Anchored = true
		end
	end
	addMessage({ type = "admin", text = "Froze " .. target.Name .. "." })
end

local function premiumUnfreeze(target)
	local hum = getHumanoid(target)
	local char = getCharacter(target)
	if not hum or not char then addMessage({ type = "error", text = target.Name .. " has no character." }) return end

	frozenPlayers[target.UserId] = nil
	hum.WalkSpeed  = 16
	hum.JumpPower  = 50
	hum.JumpHeight = 7.2

	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Anchored = false
		end
	end
	addMessage({ type = "admin", text = "Unfroze " .. target.Name .. "." })
end

local function premiumBring(target)
	if isPremium(target) then
		addMessage({ type = "error", text = "Cannot bring a vexonhub-premium user." })
		return
	end
	local myRoot  = getRootPart(LocalPlayer)
	local tarRoot = getRootPart(target)
	if not myRoot or not tarRoot then addMessage({ type = "error", text = "Character not found." }) return end
	tarRoot.CFrame = myRoot.CFrame * CFrame.new(3, 0, 0)
	addMessage({ type = "admin", text = "Brought " .. target.Name .. " to you." })
end

local function premiumGoto(target)
	local myRoot  = getRootPart(LocalPlayer)
	local tarRoot = getRootPart(target)
	if not myRoot or not tarRoot then addMessage({ type = "error", text = "Character not found." }) return end
	myRoot.CFrame = tarRoot.CFrame * CFrame.new(0, 0, 3)
	addMessage({ type = "admin", text = "Teleported to " .. target.Name .. "." })
end

