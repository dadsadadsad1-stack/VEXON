local function handleCommand(rawText)
	local lower = rawText:lower()
	local args  = {}
	for word in rawText:gmatch("%S+") do table.insert(args, word) end
	local cmd = args[1] and args[1]:lower() or ""

	if cmd == "/help" then
		if localPlayerRole == "vexonhub-premium" then
			addMessage({ type = "system", text = "=== vexonhub-premium Commands ===" })
			addMessage({ type = "system", text = "/kick /fire /freeze /unfreeze /bring /goto /announce" })
			addMessage({ type = "system", text = "/spectate /unspectate /god /ungod /kill /heal /loopkill" })
			addMessage({ type = "system", text = "/stoploopkill /speed /jump /tp /noclip /invisible /spin" })
			addMessage({ type = "system", text = "/stopspin /fling /explode /crash /noclip /players /info" })
			addMessage({ type = "system", text = "=== General Commands ===" })
			addMessage({ type = "system", text = "/w /team /mute /unmute /clear /ts /help" })
		else
			addMessage({ type = "system", text = "Commands: /w [name] [msg]  /team [msg]  /mute  /unmute  /clear  /ts  /help" })
		end
		return true
	end

	if cmd == "/clear" then
		for _, child in ipairs(ScrollFrame:GetChildren()) do
			if child:IsA("Frame") then child:Destroy() end
		end
		addMessage({ type = "system", text = "Chat cleared." })
		return true
	end

	if cmd == "/ts" then
		CONFIG.TimestampsEnabled = not CONFIG.TimestampsEnabled
		addMessage({ type = "system", text = "Timestamps " .. (CONFIG.TimestampsEnabled and "enabled." or "disabled.") })
		return true
	end

	if cmd == "/mute" then
		isMuted = true
		addMessage({ type = "system", text = "Chat muted." })
		return true
	end

	if cmd == "/unmute" then
		isMuted = false
		addMessage({ type = "system", text = "Chat unmuted." })
		return true
	end

	if cmd == "/players" then
		local list = {}
		for _, p in ipairs(Players:GetPlayers()) do
			local role = isPremium(p) and "[P]" or "[U]"
			table.insert(list, role .. " " .. p.Name)
		end
		addMessage({ type = "system", text = "Players: " .. table.concat(list, ", ") })
		return true
	end

	if cmd == "/w" or cmd == "/whisper" then
		local target = args[2] and findPlayer(args[2])
		local msg    = table.concat(args, " ", 3)
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		if #msg == 0  then addMessage({ type = "error", text = "No message provided." }) return true end
		addMessage({ type = "whisper", speaker = target, text = msg, incoming = false })
		return true
	end

	if cmd == "/t" or cmd == "/team" then
		local msg = table.concat(args, " ", 2)
		if #msg == 0 then addMessage({ type = "error", text = "No message provided." }) return true end
		addMessage({ type = "team", speaker = LocalPlayer, text = msg })
		return true
	end

	if cmd == "/info" then
		local name = args[2]
		local target = name and findPlayer(name) or LocalPlayer
		addMessage({ type = "system", text = "Name: " .. target.Name })
		addMessage({ type = "system", text = "Display: " .. target.DisplayName })
		addMessage({ type = "system", text = "UserId: " .. target.UserId })
		addMessage({ type = "system", text = "Role: " .. (isPremium(target) and "vexonhub-premium" or "User") })
		addMessage({ type = "system", text = "AccountAge: " .. target.AccountAge .. " days" })
		return true
	end

	local premiumOnlyCmds = {
		"/kick","/fire","/freeze","/unfreeze","/bring","/goto","/announce",
		"/spectate","/unspectate","/god","/ungod","/kill","/heal","/loopkill",
		"/stoploopkill","/speed","/jump","/tp","/noclip","/invisible","/spin",
		"/stopspin","/fling","/explode","/crash",
	}
	for _, pc in ipairs(premiumOnlyCmds) do
		if cmd == pc then
			if localPlayerRole ~= "vexonhub-premium" then
				addMessage({ type = "error", text = "This command requires vexonhub-premium." })
				return true
			end
			break
		end
	end

	if cmd == "/kick" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumKick(target, table.concat(args, " ", 3))
		return true
	end

	if cmd == "/fire" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumFire(target)
		return true
	end

	if cmd == "/freeze" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumFreeze(target)
		return true
	end

	if cmd == "/unfreeze" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumUnfreeze(target)
		return true
	end

	if cmd == "/bring" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumBring(target)
		return true
	end

	if cmd == "/goto" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumGoto(target)
		return true
	end

	if cmd == "/announce" then
		local msg = table.concat(args, " ", 2)
		if #msg == 0 then addMessage({ type = "error", text = "No message." }) return true end
		premiumAnnounce(msg)
		return true
	end

	if cmd == "/spectate" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumSpectate(target)
		return true
	end

	if cmd == "/unspectate" then
		premiumUnspectate()
		return true
	end

	if cmd == "/god" then
		local target = args[2] and findPlayer(args[2]) or LocalPlayer
		premiumGod(target)
		return true
	end

	if cmd == "/ungod" then
		local target = args[2] and findPlayer(args[2]) or LocalPlayer
		premiumUngod(target)
		return true
	end

	if cmd == "/kill" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumKill(target)
		return true
	end

	if cmd == "/heal" then
		local target = args[2] and findPlayer(args[2]) or LocalPlayer
		premiumHeal(target)
		return true
	end

	if cmd == "/loopkill" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumLoopKill(target)
		return true
	end

	if cmd == "/stoploopkill" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumStopLoopKill(target)
		return true
	end

	if cmd == "/speed" then
		local target = args[2] and findPlayer(args[2]) or LocalPlayer
		local speed  = tonumber(args[3] or args[2]) or 16
		if tonumber(args[2]) then target = LocalPlayer speed = tonumber(args[2]) end
		premiumSpeed(target, speed)
		return true
	end

	if cmd == "/jump" then
		local target = args[2] and findPlayer(args[2]) or LocalPlayer
		local power  = tonumber(args[3] or args[2]) or 50
		if tonumber(args[2]) then target = LocalPlayer power = tonumber(args[2]) end
		premiumJump(target, power)
		return true
	end

	if cmd == "/tp" then
		if args[4] then
			local x, y, z = tonumber(args[2]), tonumber(args[3]), tonumber(args[4])
			if x and y and z then premiumTP(LocalPlayer, x, y, z) end
		elseif args[2] then
			local target = findPlayer(args[2])
			if target then premiumGoto(target) end
		end
		return true
	end

	if cmd == "/noclip" then
		premiumNoclip(true)
		return true
	end

	if cmd == "/invisible" then
		premiumInvisible(true)
		return true
	end

	if cmd == "/visible" then
		premiumInvisible(false)
		return true
	end

	if cmd == "/spin" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumSpin(target)
		return true
	end

	if cmd == "/stopspin" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumStopSpin(target)
		return true
	end

	if cmd == "/fling" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumFling(target)
		return true
	end

	if cmd == "/explode" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumExplode(target)
		return true
	end

	if cmd == "/crash" then
		local target = args[2] and findPlayer(args[2])
		if not target then addMessage({ type = "error", text = "Player not found." }) return true end
		premiumCrash(target)
		return true
	end

	return false
end

local function sendMessage(text)
	text = text:match("^%s*(.-)%s*$")
	if #text == 0 then return end
	if #text > CONFIG.MaxMessageLength then
		addMessage({ type = "error", text = "Message too long." })
		return
	end
	if isMuted then
		addMessage({ type = "error", text = "You are muted." })
		return
	end

	if text:sub(1,1) == "/" then
		local handled = handleCommand(text)
		if handled then return end
		addMessage({ type = "error", text = 'Unknown command. Type /help.' })
		return
	end

	addMessage({ type = "chat", speaker = LocalPlayer, text = text })
	local char = LocalPlayer.Character
	if char then createChatBubble(char, text) end

	-- Broadcast to relay server
	task.spawn(function()
		pcall(function()
			local reqFunc = syn and syn.request or http and http.request or request
			reqFunc({
				Url     = RELAY_URL .. "/api/send",
				Method  = "POST",
				Headers = { ["Content-Type"] = "application/json" },
				Body    = HttpService:JSONEncode({
					secret   = RELAY_SECRET,
					username = LocalPlayer.Name,
					text     = text,
				}),
			})
		end)
	end)
end

-- Poll relay server for messages from other clients
task.spawn(function()
	while true do
		task.wait(POLL_INTERVAL)
		pcall(function()
			local url  = RELAY_URL .. "/api/poll?after=" .. lastSeenId
			local response = game:HttpGet(url, true)
			local data = HttpService:JSONDecode(response)
			if data then
				for _, msg in ipairs(data) do
					if msg.id > lastSeenId then
						lastSeenId = msg.id
						if msg.username ~= LocalPlayer.Name then
							local isPrem  = whitelistedUsers[msg.username:lower()]
							local roleTag = isPrem
								and '<font color="#FFD700"><b>[vexonhub-premium]</b></font> '
								or  '<font color="#aaaaaa">[User]</font> '
							addMessage({
								type     = "relay",
								roleTag  = roleTag,
								username = msg.username,
								text     = msg.text,
							})
						end
					end
				end
			end
		end)
	end
end)

InputBox.Focused:Connect(function()
	if not isChatOpen then setChatOpen(true) end
	NotifDot.BackgroundTransparency = 1
	lastActivityTime = tick()
end)

InputBox.FocusLost:Connect(function(enterPressed)
	if enterPressed and #InputBox.Text > 0 then
		sendMessage(InputBox.Text)
	end
	InputBox.Text = ""
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.Slash then
		if not isChatOpen then setChatOpen(true) end
		InputBox:CaptureFocus()
	elseif input.KeyCode == Enum.KeyCode.Escape then
		InputBox:ReleaseFocus()
		setChatOpen(false)
	end
end)

RunService.Heartbeat:Connect(function()
	if not isChatOpen then return end
	local elapsed = tick() - lastActivityTime
	if isChatVisible and not InputBox:IsFocused() then
		if elapsed >= CONFIG.ChatFadeDelay then
			TweenService:Create(ScrollFrame, TweenInfo.new(CONFIG.ChatFadeTime), {BackgroundTransparency = 1}):Play()
			for _, row in ipairs(ScrollFrame:GetChildren()) do
				if row:IsA("Frame") then
					for _, lbl in ipairs(row:GetChildren()) do
						if lbl:IsA("TextLabel") then
							TweenService:Create(lbl, TweenInfo.new(CONFIG.ChatFadeTime), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
						end
					end
				end
			end
			isChatVisible = false
		end
	elseif not isChatVisible and InputBox:IsFocused() then
		TweenService:Create(ScrollFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1 - CONFIG.BackgroundAlpha}):Play()
		for _, row in ipairs(ScrollFrame:GetChildren()) do
			if row:IsA("Frame") then
				for _, lbl in ipairs(row:GetChildren()) do
					if lbl:IsA("TextLabel") then
						TweenService:Create(lbl, TweenInfo.new(0.3), {BackgroundTransparency = 0.45, TextTransparency = 0}):Play()
					end
				end
			end
		end
		isChatVisible = true
		lastActivityTime = tick()
	end
end)

