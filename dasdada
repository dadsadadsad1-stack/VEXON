local function fetchWhitelist()
	local success, result = pcall(function()
		return game:HttpGet(WHITELIST_URL, true)
	end)
	if not success or not result then return end

	for line in result:gmatch("[^\r\n]+") do
		line = line:match("^%s*(.-)%s*$")
		if #line > 0 then
			local cols = {}
			for col in (line .. "|"):gmatch("([^|]*)|") do
				table.insert(cols, col)
			end

			local robloxName = cols[3]
			local status     = cols[#cols]

			if robloxName and status then
				robloxName = robloxName:match("^%s*(.-)%s*$")
				status     = status:match("^%s*(.-)%s*$")

				local validStatus = (
					status == "ACTIVE"    or
					status == "TEMPORARY" or
					status:find("^SLOT%d+_ACTIVE$") ~= nil
				)

				local validName = (
					#robloxName > 0         and
					robloxName ~= "PENDING" and
					not robloxName:find("^PENDING_")
				)

				if validStatus and validName then
					whitelistedUsers[robloxName:lower()] = true
				end
			end
		end
	end

	if whitelistedUsers[LocalPlayer.Name:lower()] then
		localPlayerRole = "vexonhub-premium"
	end
end

task.spawn(fetchWhitelist)

local function isPremium(player)
	return whitelistedUsers[player.Name:lower()] == true
end

local function getNameColor(player)
	if isPremium(player) then return PREMIUM_COLOR end
	if not playerColorMap[player.UserId] then
		playerColorMap[player.UserId] = NAME_COLORS[(player.UserId % #NAME_COLORS) + 1]
	end
	return playerColorMap[player.UserId]
end

local function getRoleTag(player)
	if isPremium(player) then
		return '<font color="#FFD700"><b>[vexonhub-premium]</b></font> '
	end
	return '<font color="#aaaaaa">[User]</font> '
end

local function getTimestamp()
	local t = os.date("*t")
	return string.format("%02d:%02d", t.hour, t.min)
end

local function filterText(text) return text end

local function truncate(text, maxLen)
	return #text > maxLen and text:sub(1, maxLen) .. "..." or text
end

local function findPlayer(name)
	local lower = name:lower()
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Name:lower() == lower or p.DisplayName:lower() == lower then
			return p
		end
	end
end

local function getCharacter(player)
	return player and player.Character
end

local function getRootPart(player)
	local char = getCharacter(player)
	return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
end

local function getHumanoid(player)
	local char = getCharacter(player)
	return char and char:FindFirstChildOfClass("Humanoid")
end

