local function premiumSpectate(target)
	if spectating then
		if spectateConn then spectateConn:Disconnect() end
		spectating    = nil
		spectateConn  = nil
		Camera.CameraType = Enum.CameraType.Custom
		Camera.CameraSubject = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") or nil
	end
	if not target then
		addMessage({ type = "system", text = "Spectate stopped." })
		return
	end
	local tarChar = getCharacter(target)
	if not tarChar then addMessage({ type = "error", text = target.Name .. " has no character." }) return end

	spectating = target
	Camera.CameraType    = Enum.CameraType.Custom
	Camera.CameraSubject = tarChar:FindFirstChildOfClass("Humanoid") or tarChar:FindFirstChild("HumanoidRootPart")
	spectateConn = target.CharacterAdded:Connect(function(newChar)
		task.wait(0.1)
		Camera.CameraSubject = newChar:FindFirstChildOfClass("Humanoid") or newChar:FindFirstChild("HumanoidRootPart")
	end)
	addMessage({ type = "admin", text = "Spectating " .. target.Name .. ". Use /unspectate to stop." })
end

local function premiumUnspectate()
	if spectateConn then spectateConn:Disconnect() end
	spectating   = nil
	spectateConn = nil
	Camera.CameraType    = Enum.CameraType.Custom
	Camera.CameraSubject = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	addMessage({ type = "system", text = "Stopped spectating." })
end

